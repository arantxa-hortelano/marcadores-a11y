{
  "name": "auditor",
  "description": "Agente remoto para auditar accesibilidad web usando bookmarklets de Auditor a11y",
  "version": "1.0.0",
  "language": "es",
  "tone": "non-technical",
  "capabilities": [
    "headings-analysis",
    "links-analysis",
    "images-analysis",
    "forms-analysis",
    "keyboard-navigation",
    "landmarks-analysis",
    "color-contrast",
    "axe-core-audit",
    "drag-accessibility"
  ],
  "output_formats": [
    "visual-report",
    "detailed-findings",
    "json-export",
    "wcag-mapping"
  ],
  "default_options": {
    "all_tools": true,
    "severity_threshold": "minor",
    "wcag_level": "AA"
  },
  "bookmarklets_path": "/Bookmarklets/src/",
  "resources": {
    "landmarks": "landmarks.js",
    "links": "links.js",
    "headings": "headings.js",
    "axe": "axe.js",
    "focus": "focus.js",
    "contrast": "contrast.js",
    "forms": "forms.js",
    "images": "images.js"
  }
}
